{
    "$schema": "https://opencode.ai/config.json",
    "permission": {
        "lsp": "allow",
        "skill": "allow",
        "webfetch": "allow",
        "question": "allow",
        "external_directory": "ask",
        "read": {
            "*": "allow",
            "*.env": "deny",
            "*.env.*": "deny",
            "*.env.example": "allow"
        },
        "edit": "allow",
        "write": "allow"
    },
    "instructions": [
        "./README.md",
        "./AGENTS.md"
    ],
    "formatter": {
        "ruff": {
            "command": [
                "ruff",
                "format",
                "$FILE"
            ],
            "extensions": [
                ".py",
                ".pyi"
            ]
        }
    },
    "lsp": {
        "pyright": {
            "disabled": true
        },
        "basedpyright": {
            "disabled": false,
            "command": [
                "basedpyright-langserver",
                "--stdio"
            ],
            "extensions": [
                ".py",
                ".pyi"
            ]
        }
    }
}
